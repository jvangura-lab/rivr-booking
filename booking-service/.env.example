# Local dev config. In production these are injected via Cloud Run + Secret Manager.

# ─── Server
PORT=8080
LOG_LEVEL=INFO

# ─── Google credentials
# Path to a service account JSON file (local dev). In Cloud Run, prefer
# GOOGLE_SA_KEY_JSON with the full JSON contents (sourced from Secret Manager).
GOOGLE_APPLICATION_CREDENTIALS=/Users/jonasvangura/rivr-booking-sa-key.json
# GOOGLE_SA_KEY_JSON={"type":"service_account",...}

# Workspace user that the service account impersonates (DWD).
# This account owns booked events and sends the confirmation email.
IMPERSONATE_USER=founder@yourdomain.com

# Comma-separated guest emails added to every booking event.
GUEST_EMAILS=cofounder@yourdomain.com

# ─── Availability rules
WORKING_HOURS_START=9
WORKING_HOURS_END=17
WORKING_DAYS=Mon,Tue,Wed,Thu,Fri
MEETING_DURATION_MIN=30
LOOKAHEAD_DAYS=14
FOUNDER_TIMEZONE=America/Los_Angeles
BUFFER_MIN=15

# ─── Email
CONFIRMATION_FROM_NAME=RIVR
CONFIRMATION_SUBJECT_PREFIX=Walkthrough confirmed

# ─── CORS
# Only needed when the widget is embedded from a different origin than the API.
# Same-origin (Flask serving the bundle) bypasses CORS entirely.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── Dev mode
# When true, /api/availability returns fake slots instead of hitting Google Calendar.
# Useful for frontend dev without setting up DWD.
FAKE_CALENDAR=true
